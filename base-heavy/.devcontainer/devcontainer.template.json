{
    "name": "Base Heavy Template",
    "image": "ghcr.io/agentcluck77/devcontainer-stripped-base-heavy:main",
    "remoteUser": "dev-user",
    "containerUser": "dev-user",
    "updateRemoteUserUID": true,
    "workspaceFolder": "/workspaces/content",
    // SELinux fix: Disable SELinux label enforcement to prevent permission denied errors.
    // This avoids duplicate mount errors that can happen when using :Z or :z flags.
    // Reference: https://github.com/loft-sh/devpod/issues/1283
    "securityOpt": ["label=disable"],

    // Optional GPU access (Podman/NVIDIA CDI).
    // "runArgs": ["--device", "nvidia.com/gpu=all"],
    // "containerEnv": {
    //     "NVIDIA_VISIBLE_DEVICES": "all",
    //     "NVIDIA_DRIVER_CAPABILITIES": "compute,utility"
    // },

    // Optional extra mount.
    // "mounts": ["source=/mnt/aloy,target=/mnt/aloy,type=bind"],

    // Alternative Linuxbrew fix if /var inside brew prefix is missing.
    // "postCreateCommand": "sudo mkdir -p /home/linuxbrew/.linuxbrew/var && sudo chown -R dev-user:dev-user /home/linuxbrew/.linuxbrew/var || true",

    // Uncomment if Homebrew write permissions break after UID remap.
    // "postCreateCommand": "sudo chown -R $(id -u):$(id -g) /home/linuxbrew/.linuxbrew && bash .devcontainer/build.sh",
    "postCreateCommand": "bash .devcontainer/build.sh",

    "settings": {},
    "extensions": []
}
